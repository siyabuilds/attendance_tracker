// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String @id @default(uuid())
  email    String @unique
  password String
}

model Event {
  id          String       @id @default(uuid())
  title       String
  description String?
  venue       String
  locationUrl String?
  startsAt    DateTime
  endsAt      DateTime
  rewardPoints Int          @default(10)
  pointGraceMinutes Int     @default(15)
  pointDecayIntervalMinutes Int @default(15)
  pointDecayPercent Int     @default(10)
  minimumPoints Int         @default(1)
  token       String       @unique
  createdAt   DateTime     @default(now())
  attendances Attendance[]
  questions   EventQuestion[]

  @@map("events")
}

model Attendance {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  email     String
  pointsAwarded Int
  createdAt DateTime @default(now())
  answers   AttendanceAnswer[]

  @@unique([eventId, email])

  @@map("attendance")
}

model EventQuestion {
  id        String             @id @default(uuid())
  eventId   String
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label     String
  required  Boolean            @default(false)
  order     Int
  answers   AttendanceAnswer[]

  @@unique([eventId, order])
  @@index([eventId])

  @@map("event_questions")
}

model AttendanceAnswer {
  id           String         @id @default(uuid())
  attendanceId String
  questionId   String
  attendance   Attendance     @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  question     EventQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer       String

  @@unique([attendanceId, questionId])
  @@index([questionId])

  @@map("attendance_answers")
}
